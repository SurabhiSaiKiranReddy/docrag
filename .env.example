# ─── Provider selection ──────────────────────────────────────────────
# Embeddings: "local" (sentence-transformers, free, CPU) or "openai"
DOCRAG_EMBEDDINGS_PROVIDER=local
# LLM: "ollama" (local, free) or "openai"
DOCRAG_LLM_PROVIDER=ollama
# Vector store: "faiss" (local)
DOCRAG_VECTORSTORE_PROVIDER=faiss

# ─── OpenAI (only needed if a provider above is "openai") ────────────
# OPENAI_API_KEY=sk-your-key-here
DOCRAG_OPENAI_EMBEDDINGS_MODEL=text-embedding-3-small
DOCRAG_OPENAI_LLM_MODEL=gpt-4o-mini

# ─── Ollama (only needed if LLM provider is "ollama") ────────────────
# In WSL: either run `ollama serve` inside WSL, or point this at the
# Windows host (e.g. http://host.docker.internal:11434 or your host IP).
DOCRAG_OLLAMA_BASE_URL=http://localhost:11434
DOCRAG_OLLAMA_MODEL=llama3.2:3b

# ─── Local embeddings model ──────────────────────────────────────────
DOCRAG_LOCAL_EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ─── Chunking ────────────────────────────────────────────────────────
DOCRAG_CHUNK_SIZE=600
DOCRAG_CHUNK_OVERLAP=80

# ─── Retrieval ───────────────────────────────────────────────────────
DOCRAG_TOP_K=5

# ─── Generation ──────────────────────────────────────────────────────
DOCRAG_TEMPERATURE=0.1
DOCRAG_MAX_TOKENS=1024

# ─── Storage ─────────────────────────────────────────────────────────
DOCRAG_DATA_DIR=data
DOCRAG_INDEX_DIR=data/index
